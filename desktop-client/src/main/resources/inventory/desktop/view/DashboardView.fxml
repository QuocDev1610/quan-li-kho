<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="24.0"
      styleClass="dashboard-view"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="inventory.desktop.controller.DashboardController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
    </padding>

    <VBox spacing="6.0">
        <Label text="Analytics Dashboard" styleClass="dashboard-title"/>
        <Label text="Tổng quan nhanh hoạt động nhập xuất và tồn kho" styleClass="dashboard-subtitle"/>
    </VBox>

    <GridPane hgap="18.0" vgap="18.0">
        <columnConstraints>
            <ColumnConstraints percentWidth="25.0"/>
            <ColumnConstraints percentWidth="25.0"/>
            <ColumnConstraints percentWidth="25.0"/>
            <ColumnConstraints percentWidth="25.0"/>
        </columnConstraints>

        <VBox GridPane.columnIndex="0" spacing="14.0" styleClass="summary-card">
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <FontIcon iconLiteral="fas-box-open" iconSize="24" styleClass="summary-icon"/>
                <Label text="Tổng số mặt hàng" styleClass="summary-title"/>
            </HBox>
            <Label fx:id="totalProductsLabel" text="0" styleClass="summary-value"/>
        </VBox>

        <VBox GridPane.columnIndex="1" spacing="14.0" styleClass="summary-card">
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <FontIcon iconLiteral="fas-arrow-circle-down" iconSize="24" styleClass="summary-icon"/>
                <Label text="Phiếu nhập tháng này" styleClass="summary-title"/>
            </HBox>
            <Label fx:id="monthlyReceiptsLabel" text="0" styleClass="summary-value"/>
        </VBox>

        <VBox GridPane.columnIndex="2" spacing="14.0" styleClass="summary-card">
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <FontIcon iconLiteral="fas-arrow-circle-up" iconSize="24" styleClass="summary-icon"/>
                <Label text="Phiếu xuất tháng này" styleClass="summary-title"/>
            </HBox>
            <Label fx:id="monthlyIssuesLabel" text="0" styleClass="summary-value"/>
        </VBox>

        <VBox GridPane.columnIndex="3" spacing="14.0" styleClass="summary-card summary-card-danger">
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <FontIcon iconLiteral="fas-exclamation-triangle" iconSize="24" styleClass="summary-icon-danger"/>
                <Label text="Cảnh báo sắp hết" styleClass="summary-title"/>
            </HBox>
            <Label fx:id="lowStockLabel" text="0" styleClass="summary-value"/>
        </VBox>
    </GridPane>

    <GridPane hgap="22.0" vgap="22.0" VBox.vgrow="ALWAYS">
        <columnConstraints>
            <ColumnConstraints percentWidth="64.0"/>
            <ColumnConstraints percentWidth="36.0"/>
        </columnConstraints>

        <VBox GridPane.columnIndex="0" spacing="16.0" styleClass="dashboard-card" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="4.0">
                    <Label text="Xu hướng nhập / xuất hàng" styleClass="section-title"/>
                    <Label text="Dữ liệu tổng hợp trực tiếp từ hệ thống kho" styleClass="section-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="2026" styleClass="dashboard-badge"/>
            </HBox>

            <BarChart fx:id="inventoryFlowChart" animated="false" legendVisible="true" VBox.vgrow="ALWAYS">
                <xAxis>
                    <CategoryAxis label="Tháng"/>
                </xAxis>
                <yAxis>
                    <NumberAxis label="Số lượng"/>
                </yAxis>
            </BarChart>
        </VBox>

        <VBox GridPane.columnIndex="1" spacing="16.0" styleClass="dashboard-card" VBox.vgrow="ALWAYS">
            <VBox spacing="4.0">
                <Label text="Low Stock Alert" styleClass="section-title"/>
                <Label text="Sản phẩm dưới định mức tồn kho" styleClass="section-subtitle"/>
            </VBox>

            <TableView fx:id="lowStockTable" VBox.vgrow="ALWAYS" styleClass="low-stock-table">
                <columns>
                    <TableColumn fx:id="productCodeColumn" text="Mã" prefWidth="92.0"/>
                    <TableColumn fx:id="productNameColumn" text="Sản phẩm" prefWidth="150.0"/>
                    <TableColumn fx:id="quantityColumn" text="SL" prefWidth="60.0"/>
                    <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="110.0"/>
                </columns>
            </TableView>
        </VBox>
    </GridPane>
</VBox>
