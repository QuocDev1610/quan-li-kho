<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="18.0" styleClass="module-page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="inventory.desktop.controller.module.GoodsReceiptViewController">
    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/></padding>
    <VBox spacing="5.0">
        <Label fx:id="moduleTitleLabel" styleClass="module-title"/>
        <Label fx:id="moduleSubtitleLabel" styleClass="module-subtitle"/>
    </VBox>
    <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="module-toolbar">
        <TextField fx:id="searchField" promptText="Tìm kiếm phiếu nhập..." HBox.hgrow="ALWAYS" styleClass="module-search"/>
        <Button fx:id="refreshButton" text="Làm mới" onAction="#refresh" styleClass="button-primary"/>
        <Button fx:id="addButton" text="Tạo phiếu" styleClass="button-success"/>
        <Button fx:id="editButton" text="Sửa" styleClass="button-primary"/>
        <Button fx:id="deleteButton" text="Xóa" styleClass="button-danger"/>
        <Button fx:id="exportButton" text="Xuất Excel" onAction="#exportToExcel" styleClass="button-export">
            <graphic>
                <FontIcon iconLiteral="fas-file-excel" iconSize="15"/>
            </graphic>
        </Button>
    </HBox>
    <VBox VBox.vgrow="ALWAYS" styleClass="module-card">
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS"/>
    </VBox>
</VBox>
