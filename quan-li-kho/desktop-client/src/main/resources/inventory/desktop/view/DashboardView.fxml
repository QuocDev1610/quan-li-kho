<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="18.0"
      styleClass="dashboard-view"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="inventory.desktop.controller.DashboardController">

    <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="dashboard-overview">
        <VBox spacing="3.0">
            <Label text="Tổng quan vận hành" styleClass="dashboard-section-heading"/>
            <Label text="Các chỉ số quan trọng được tổng hợp trực tiếp từ hệ thống kho"
                   styleClass="dashboard-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox alignment="CENTER" spacing="7.0" styleClass="live-data-badge">
            <StackPane styleClass="live-data-dot"/>
            <Label text="Dữ liệu trực tiếp"/>
        </HBox>
    </HBox>

    <GridPane hgap="16.0">
        <columnConstraints>
            <ColumnConstraints percentWidth="25.0"/>
            <ColumnConstraints percentWidth="25.0"/>
            <ColumnConstraints percentWidth="25.0"/>
            <ColumnConstraints percentWidth="25.0"/>
        </columnConstraints>

        <HBox GridPane.columnIndex="0" alignment="CENTER_LEFT" spacing="16.0" styleClass="summary-card">
            <StackPane styleClass="summary-icon-box">
                <FontIcon iconLiteral="fas-box-open" iconSize="21" styleClass="summary-icon"/>
            </StackPane>
            <VBox spacing="5.0">
                <Label text="Tổng mặt hàng" styleClass="summary-title"/>
                <Label fx:id="totalProductsLabel" text="0" styleClass="summary-value"/>
                <Label text="Đang quản lý trong kho" styleClass="summary-caption"/>
            </VBox>
        </HBox>

        <HBox GridPane.columnIndex="1" alignment="CENTER_LEFT" spacing="16.0" styleClass="summary-card">
            <StackPane>
                <styleClass>
                    <String fx:value="summary-icon-box"/>
                    <String fx:value="summary-icon-box-success"/>
                </styleClass>
                <FontIcon iconLiteral="fas-arrow-down" iconSize="20">
                    <styleClass>
                        <String fx:value="summary-icon"/>
                        <String fx:value="summary-icon-success"/>
                    </styleClass>
                </FontIcon>
            </StackPane>
            <VBox spacing="5.0">
                <Label text="Phiếu nhập" styleClass="summary-title"/>
                <Label fx:id="monthlyReceiptsLabel" text="0" styleClass="summary-value"/>
                <Label text="Trong tháng hiện tại" styleClass="summary-caption"/>
            </VBox>
        </HBox>

        <HBox GridPane.columnIndex="2" alignment="CENTER_LEFT" spacing="16.0" styleClass="summary-card">
            <StackPane>
                <styleClass>
                    <String fx:value="summary-icon-box"/>
                    <String fx:value="summary-icon-box-violet"/>
                </styleClass>
                <FontIcon iconLiteral="fas-arrow-up" iconSize="20">
                    <styleClass>
                        <String fx:value="summary-icon"/>
                        <String fx:value="summary-icon-violet"/>
                    </styleClass>
                </FontIcon>
            </StackPane>
            <VBox spacing="5.0">
                <Label text="Phiếu xuất" styleClass="summary-title"/>
                <Label fx:id="monthlyIssuesLabel" text="0" styleClass="summary-value"/>
                <Label text="Trong tháng hiện tại" styleClass="summary-caption"/>
            </VBox>
        </HBox>

        <HBox GridPane.columnIndex="3" alignment="CENTER_LEFT" spacing="16.0">
            <styleClass>
                <String fx:value="summary-card"/>
                <String fx:value="summary-card-danger"/>
            </styleClass>
            <StackPane>
                <styleClass>
                    <String fx:value="summary-icon-box"/>
                    <String fx:value="summary-icon-box-danger"/>
                </styleClass>
                <FontIcon iconLiteral="fas-exclamation-triangle" iconSize="20"
                          styleClass="summary-icon-danger"/>
            </StackPane>
            <VBox spacing="5.0">
                <Label text="Sắp hết hàng" styleClass="summary-title"/>
                <Label fx:id="lowStockLabel" text="0" styleClass="summary-value-danger"/>
                <Label text="Cần kiểm tra tồn kho" styleClass="summary-caption-danger"/>
            </VBox>
        </HBox>
    </GridPane>

    <GridPane hgap="18.0" VBox.vgrow="ALWAYS">
        <columnConstraints>
            <ColumnConstraints percentWidth="67.0"/>
            <ColumnConstraints percentWidth="33.0"/>
        </columnConstraints>

        <VBox GridPane.columnIndex="0" spacing="14.0" styleClass="dashboard-card" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="3.0">
                    <Label text="Xu hướng nhập và xuất kho" styleClass="section-title"/>
                    <Label text="Số lượng hàng hóa luân chuyển theo từng tháng"
                           styleClass="section-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="8.0" styleClass="chart-period-badge">
                    <FontIcon iconLiteral="fas-calendar-alt" iconSize="13"/>
                    <Label fx:id="currentYearLabel" text="2026"/>
                </HBox>
            </HBox>

            <BarChart fx:id="inventoryFlowChart"
                      animated="false"
                      legendSide="BOTTOM"
                      legendVisible="true"
                      VBox.vgrow="ALWAYS">
                <xAxis>
                    <CategoryAxis label="Tháng"/>
                </xAxis>
                <yAxis>
                    <NumberAxis forceZeroInRange="true" label="Số lượng"/>
                </yAxis>
            </BarChart>
        </VBox>

        <VBox GridPane.columnIndex="1" spacing="14.0" styleClass="dashboard-card" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="3.0">
                    <Label text="Cảnh báo tồn kho" styleClass="section-title"/>
                    <Label text="Sản phẩm dưới định mức an toàn" styleClass="section-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <FontIcon iconLiteral="fas-exclamation-circle" iconSize="17"
                          styleClass="stock-alert-icon"/>
            </HBox>

            <TableView fx:id="lowStockTable"
                       fixedCellSize="58.0"
                       VBox.vgrow="ALWAYS"
                       styleClass="low-stock-table">
                <columns>
                    <TableColumn fx:id="productCodeColumn" text="Mã" styleClass="column-left"/>
                    <TableColumn fx:id="productNameColumn" text="Sản phẩm" styleClass="column-left"/>
                    <TableColumn fx:id="quantityColumn" text="SL" styleClass="column-center"/>
                    <TableColumn fx:id="statusColumn" text="Trạng thái" styleClass="column-center"/>
                </columns>
            </TableView>
        </VBox>
    </GridPane>
</VBox>
