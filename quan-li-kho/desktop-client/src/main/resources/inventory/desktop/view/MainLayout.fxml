<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane fx:id="root"
            prefHeight="780.0"
            prefWidth="1280.0"
            styleClass="app-root"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="inventory.desktop.controller.MainLayoutController">
    <left>
        <VBox prefWidth="280.0" spacing="10.0" styleClass="sidebar">
            <padding>
                <Insets bottom="24.0" left="22.0" right="22.0" top="24.0"/>
            </padding>

            <Label text="Inventory" styleClass="brand-title"/>
            <Label text="Warehouse Admin" styleClass="brand-subtitle"/>

            <Region prefHeight="22.0"/>

            <Button fx:id="dashboardButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#openDashboard" text="Dashboard" styleClass="sidebar-button">
                <graphic><FontIcon iconLiteral="fas-chart-pie" iconSize="16"/></graphic>
            </Button>
            <Button fx:id="categoriesButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#openCategories" text="Categories" styleClass="sidebar-button">
                <graphic><FontIcon iconLiteral="fas-layer-group" iconSize="16"/></graphic>
            </Button>
            <Button fx:id="productsButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#openProducts" text="Products" styleClass="sidebar-button">
                <graphic><FontIcon iconLiteral="fas-box-open" iconSize="16"/></graphic>
            </Button>
            <Button fx:id="goodsReceiptsButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#openGoodsReceipts" text="Goods Receipts" styleClass="sidebar-button">
                <graphic><FontIcon iconLiteral="fas-arrow-circle-down" iconSize="16"/></graphic>
            </Button>
            <Button fx:id="goodsIssuesButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#openGoodsIssues" text="Goods Issues" styleClass="sidebar-button">
                <graphic><FontIcon iconLiteral="fas-arrow-circle-up" iconSize="16"/></graphic>
            </Button>
            <Button fx:id="inStockButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#openInStock" text="In Stock" styleClass="sidebar-button">
                <graphic><FontIcon iconLiteral="fas-warehouse" iconSize="16"/></graphic>
            </Button>
            <Button fx:id="usersButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#openUsers" text="Users" styleClass="sidebar-button">
                <graphic><FontIcon iconLiteral="fas-users" iconSize="16"/></graphic>
            </Button>
            <Button fx:id="chatButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#openChat" text="AI Assistant" styleClass="sidebar-button">
                <graphic><FontIcon iconLiteral="fas-comments" iconSize="16"/></graphic>
            </Button>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="6.0" styleClass="sidebar-profile">
                <Label text="Signed in as" styleClass="profile-caption"/>
                <Label fx:id="accountLabel" text="admin@inventory" styleClass="profile-name"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <BorderPane styleClass="workspace">
            <top>
                <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="header">
                    <padding>
                        <Insets bottom="14.0" left="28.0" right="28.0" top="14.0"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT" spacing="13.0" styleClass="header-page-info">
                        <StackPane styleClass="header-page-icon-box">
                            <FontIcon fx:id="pageIcon" iconLiteral="fas-chart-pie" iconSize="18"
                                      styleClass="header-page-icon"/>
                        </StackPane>
                        <VBox spacing="2.0">
                            <Label fx:id="pageTitleLabel" text="Dashboard" styleClass="page-title"/>
                            <Label fx:id="pageSubtitleLabel" text="Tổng quan hệ thống kho"
                                   styleClass="page-subtitle"/>
                        </VBox>
                    </HBox>

                    <Region HBox.hgrow="ALWAYS" minWidth="8.0"/>

                    <HBox alignment="CENTER_LEFT"
                          maxWidth="440.0"
                          minWidth="220.0"
                          prefWidth="400.0"
                          spacing="10.0"
                          styleClass="header-search"
                          HBox.hgrow="ALWAYS">
                        <FontIcon iconLiteral="fas-search" iconSize="15" styleClass="header-search-icon"/>
                        <TextField fx:id="globalSearchField"
                                   promptText="Tìm kiếm trong hệ thống..."
                                   styleClass="header-search-input"
                                   HBox.hgrow="ALWAYS"/>
                        <Label text="Ctrl K" styleClass="search-shortcut"/>
                    </HBox>

                    <Region HBox.hgrow="ALWAYS" minWidth="8.0"/>

                    <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="header-actions">
                        <StackPane fx:id="notificationButton"
                                   onMouseClicked="#showNotifications"
                                   styleClass="notification-button">
                            <FontIcon iconLiteral="fas-bell" iconSize="17" styleClass="notification-icon"/>
                            <Circle radius="4.0" styleClass="notification-dot" StackPane.alignment="TOP_RIGHT">
                                <StackPane.margin>
                                    <Insets right="5.0" top="5.0"/>
                                </StackPane.margin>
                            </Circle>
                        </StackPane>

                        <Region styleClass="header-divider"/>

                        <HBox fx:id="profileArea"
                              alignment="CENTER_LEFT"
                              onMouseClicked="#showProfileMenu"
                              spacing="10.0"
                              styleClass="profile-area">
                            <StackPane minHeight="40.0" minWidth="40.0"
                                       prefHeight="40.0" prefWidth="40.0"
                                       styleClass="profile-avatar">
                                <Label fx:id="avatarInitialLabel" text="Q" styleClass="profile-avatar-text"/>
                                <Circle radius="4.5" styleClass="profile-online-dot"
                                        StackPane.alignment="BOTTOM_RIGHT"/>
                            </StackPane>
                            <VBox spacing="1.0">
                                <Label fx:id="profileNameLabel" text="Lê Ngọc Quốc"
                                       styleClass="profile-display-name"/>
                                <Label text="Quản trị viên" styleClass="profile-role"/>
                            </VBox>
                            <FontIcon iconLiteral="fas-chevron-down" iconSize="11"
                                      styleClass="profile-chevron"/>
                        </HBox>
                    </HBox>
                </HBox>
            </top>

            <center>
                <StackPane fx:id="contentArea" styleClass="content-area">
                    <padding>
                        <Insets bottom="28.0" left="28.0" right="28.0" top="24.0"/>
                    </padding>
                </StackPane>
            </center>
        </BorderPane>
    </center>
</BorderPane>
